{
  "name": "telemedi/test-purposes",
  "description": "Exchange office application for recruitment task",
  "license": "proprietary",
  "autoload": {
    "psr-4": {
      "App\\": "src/App/"
    },
    "classmap": [
      "src/Kernel.php"
    ]
  },
  "config": {
    "platform": {
      "php": "8.2.0"
    },
    "sort-packages": true,
    "allow-plugins": {
      "symfony/flex": true
    }
  },
  "require": {
    "doctrine/annotations": "^1.14",
    "guzzlehttp/guzzle": "^7.9",
    "symfony/cache": "^4.4",
    "symfony/dotenv": "^4.4",
    "symfony/flex": "^1.21",
    "symfony/http-kernel": "^4.4",
    "symfony/twig-bundle": "^4.4.30",
    "symfony/webpack-encore-bundle": "^1.17",
    "symfony/yaml": "^4.4"
  },
  "conflict": {
    "symfony/symfony": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^8.5",
    "symfony/browser-kit": "^5.4",
    "symfony/css-selector": "^5.4",
    "symfony/maker-bundle": "^1.39",
    "symfony/phpunit-bridge": "^6.3"
  },
  "scripts": {
  "auto-scripts": {
    "cache:clear": "symfony-cmd",
    "assets:install %PUBLIC_DIR%": "symfony-cmd"
  },
    "test": "vendor/bin/phpunit --colors=always",
    "test:unit": "vendor/bin/phpunit --testsuite=unit --colors=always",
    "test:ci": "vendor/bin/phpunit --coverage-clover build/coverage/clover.xml --colors=always",
    "check:composer": "composer validate --no-check-publish --strict && composer dump-autoload -o -a",
    "check:audit": "composer audit"
  }
}
